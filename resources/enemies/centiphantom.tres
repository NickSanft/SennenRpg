ActResultTexts = PackedStringArray("* 60 HP. Bioluminescent scales.\n* Looks lonely.", "* You reach out. It nudges your hand cautiously.", "* You hum softly. The Centiphantom harmonizes.", "* You produce a small light. It stares, transfixed.")
BattleDialogLines = PackedStringArray("* ...glub.", "* (It pulses faintly.)", "* The water feels cold here.", "* It circles you warily.")
GoldDrop = 15
ExpDrop = 10
