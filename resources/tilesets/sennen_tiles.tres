[gd_resource type="TileSet" load_steps=3 format=3 uid="uid://sennentiles_shared"]

; Shared Sennen tileset — used by all dungeon floor maps.
; After opening in the editor:
;   1. Select this resource in the TileSet panel.
;   2. Add a Physics Layer (Project > TileSet > Add Physics Layer) so wall tiles can have collision.
;   3. Paint collision shapes on wall tiles in the TileSet editor.
;   4. Optionally add Terrain Sets for autotiling.

