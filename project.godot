; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="SennenRpg"
run/main_scene="res://scenes/boot/Boot.tscn"
config/features=PackedStringArray("4.6", "C#", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

PhantomCameraManager="*uid://duq6jhf6unyis"
GameManager="*uid://dt7n460r0x1ba"
SaveManager="*uid://cjse2ggsmh0rk"
AudioManager="*uid://0egl0iuwbud4"
SceneTransition="*uid://cdnm7y7mvnus8"
DialogicBridge="*uid://cdaesqlsosbyi"
BattleRegistry="*uid://d36wu2sl1eacd"
Dialogic="*uid://ds2q0uclmolvu"
DialogRegistry="*res://autoloads/DialogRegistry.cs"
RhythmClock="*res://autoloads/RhythmClock.cs"

[dialogic]

directories/dch_directory={
"Foran": "res://dialog/characters/Foran.dch",
"TestNpc": "res://dialog/characters/Shizu.dch",
"unit_test_character": "res://addons/dialogic/Tests/Resources/unit_test_character.dch"
}
directories/dtl_directory={
"battle_charm_result": "res://dialog/timelines/battle_charm_result.dtl",
"battle_charm_spare_ready": "res://dialog/timelines/battle_charm_spare_ready.dtl",
"battle_enemy_dialog": "res://dialog/timelines/battle_enemy_dialog.dtl",
"battle_fled": "res://dialog/timelines/battle_fled.dtl",
"battle_flee_blocked": "res://dialog/timelines/battle_flee_blocked.dtl",
"battle_game_over": "res://dialog/timelines/battle_game_over.dtl",
"battle_hit": "res://dialog/timelines/battle_hit.dtl",
"battle_intro": "res://dialog/timelines/battle_intro.dtl",
"battle_item_gone": "res://dialog/timelines/battle_item_gone.dtl",
"battle_item_nothing": "res://dialog/timelines/battle_item_nothing.dtl",
"battle_item_used": "res://dialog/timelines/battle_item_used.dtl",
"battle_mercy_ignored": "res://dialog/timelines/battle_mercy_ignored.dtl",
"battle_no_items": "res://dialog/timelines/battle_no_items.dtl",
"battle_skill_result": "res://dialog/timelines/battle_skill_result.dtl",
"battle_skill_spare_ready": "res://dialog/timelines/battle_skill_spare_ready.dtl",
"battle_spared": "res://dialog/timelines/battle_spared.dtl",
"battle_strike_prompt": "res://dialog/timelines/battle_strike_prompt.dtl",
"battle_victory": "res://dialog/timelines/battle_victory.dtl",
"npc_foran": "res://dialog/timelines/npc_foran.dtl",
"npc_test_after": "res://dialog/timelines/npc_test_after.dtl",
"save_point_prompt": "res://dialog/timelines/save_point_prompt.dtl",
"timelines/npc_test_hello": "res://dialog/timelines/shizu.dtl",
"walkin_north_exit": "res://dialog/timelines/walkin_north_exit.dtl"
}
layout/style_directory={
"": "res://assets/styles/Default.tres",
"Default": "res://assets/styles/Default.tres"
}
layout/style_list=["res://assets/styles/Default.tres"]
layout/default_style="res://assets/styles/Default.tres"
glossary/default_case_sensitive=true
variables={
"charm_result": "",
"damage": "",
"enemy_dialog": "",
"enemy_name": "",
"exp_gained": "",
"gold_gained": "",
"heal_amount": "",
"hit_label": "",
"item_name": "",
"love": "",
"notes_success": "",
"notes_total": "",
"performance_summary": "",
"skill_result": ""
}

[dotnet]

project/assembly_name="SennenRpg"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg", "res://addons/gdUnit4/plugin.cfg", "res://addons/phantom_camera/plugin.cfg")

[importer_defaults]

texture={
&"process/fix_alpha_border": false
}

