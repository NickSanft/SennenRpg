[gd_scene format=3 uid="uid://dungeonfloor001"]

[ext_resource type="PackedScene" uid="uid://bs06dan353qo1" path="res://scenes/overworld/overworld_base.tscn" id="1_base"]
[ext_resource type="Script" path="res://scenes/overworld/maps/dungeon/DungeonFloor1.cs" id="2_script"]
[ext_resource type="TileSet" uid="uid://bpmahlkk4y1kg" path="res://resources/tilesets/sennen_tiles.tres" id="3_tileset"]
[ext_resource type="Script" uid="uid://hcefwe11an6s" path="res://scenes/overworld/objects/SpawnPoint.cs" id="4_spawn"]
[ext_resource type="Script" uid="uid://ctpvffxw8avmu" path="res://scenes/overworld/objects/MapExit.cs" id="5_mapexit"]

[sub_resource type="RectangleShape2D" id="Shape_StairsDown"]
size = Vector2(16, 16)

[sub_resource type="RectangleShape2D" id="Shape_StairsUp"]
size = Vector2(16, 16)

[node name="DungeonFloor1" instance=ExtResource("1_base")]
script = ExtResource("2_script")
MapId = "Dungeon - Floor 1"

; ── TileMapLayer tileset assignments (override inherited nodes, no type needed) ──
[node name="Ground" parent="."]
tile_set = ExtResource("3_tileset")

[node name="Ground" parent="Ground"]
tile_set = ExtResource("3_tileset")

[node name="Walls" parent="."]
tile_set = ExtResource("3_tileset")

[node name="Objects" parent="."]
tile_set = ExtResource("3_tileset")

; ── Spawn points — move to correct tile positions in the editor ───────────────
[node name="EntranceSpawn" type="Node2D" parent="."]
script = ExtResource("4_spawn")
position = Vector2(64, 64)
SpawnId = "entrance"

[node name="StairsDownSpawn" type="Node2D" parent="."]
script = ExtResource("4_spawn")
position = Vector2(128, 64)
SpawnId = "stairs_down"

; ── StairsDown: MapExit AutoTrigger → DungeonFloor2, spawn "stairs_up" ────────
[node name="StairsDown" type="Area2D" parent="."]
script = ExtResource("5_mapexit")
position = Vector2(128, 64)
TargetMapPath = "res://scenes/overworld/maps/dungeon/DungeonFloor2.tscn"
TargetSpawnId = "stairs_up"
AutoTrigger = true
ExitHint = 2

[node name="CollisionShape2D" type="CollisionShape2D" parent="StairsDown"]
shape = SubResource("Shape_StairsDown")

; ── StairsUp: plain Area2D — DungeonFloor1.cs handles this (sets WorldMapReturnTile) ──
[node name="StairsUp" type="Area2D" parent="."]
position = Vector2(64, 64)
collision_layer = 1
collision_mask = 1

[node name="CollisionShape2D" type="CollisionShape2D" parent="StairsUp"]
shape = SubResource("Shape_StairsUp")
